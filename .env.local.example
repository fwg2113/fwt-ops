# Supabase (FWT-specific project — separate from FWG)
NEXT_PUBLIC_SUPABASE_URL=https://your-fwt-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Twilio (for SMS notifications)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Email (Resend)
# RESEND_API_KEY=

# Shopify (if needed for draft orders)
# SHOPIFY_STORE_URL=
# SHOPIFY_ACCESS_TOKEN=

# Google Maps (for distance calculation)
# GOOGLE_MAPS_API_KEY=
